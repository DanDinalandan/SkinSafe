<resources>

    <!-- Base application theme -->
    <style name="Theme.SkinSafe" parent="Theme.MaterialComponents.Light.NoActionBar">
        <!-- Primary brand color -->
        <item name="colorPrimary">@color/green_primary</item>
        <item name="colorPrimaryVariant">@color/green_dark</item>
        <item name="colorOnPrimary">@color/text_white</item>
        <!-- Secondary brand color -->
        <item name="colorSecondary">@color/green_accent</item>
        <item name="colorSecondaryVariant">@color/green_medium</item>
        <item name="colorOnSecondary">@color/text_white</item>
        <!-- Error color -->
        <item name="colorError">@color/colorError</item>
        <item name="colorOnError">@color/text_white</item>
        <!-- Background -->
        <item name="android:colorBackground">@color/background</item>
        <item name="colorSurface">@color/surface_white</item>
        <item name="colorOnSurface">@color/text_primary</item>
        <!-- Status bar -->
        <item name="android:statusBarColor">@color/green_dark</item>
        <item name="android:windowLightStatusBar">false</item>
        <!-- Navigation bar -->
        <item name="android:navigationBarColor">@color/surface_white</item>
        <!-- Text styles -->
        <item name="android:textColorPrimary">@color/text_primary</item>
        <item name="android:textColorSecondary">@color/text_secondary</item>
        <!-- Button default style - rounded corners -->
        <item name="materialButtonStyle">@style/Widget.SkinSafe.Button</item>
        <!-- Card style -->
        <item name="materialCardViewStyle">@style/Widget.SkinSafe.Card</item>
        <!-- Text input style -->
        <item name="textInputStyle">@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox</item>
    </style>

    <!-- Custom Button style: rounded corners -->
    <style name="Widget.SkinSafe.Button" parent="Widget.MaterialComponents.Button">
        <item name="cornerRadius">10dp</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:letterSpacing">0</item>
    </style>

    <!-- Custom Card style -->
    <style name="Widget.SkinSafe.Card" parent="Widget.MaterialComponents.CardView">
        <item name="cardCornerRadius">12dp</item>
        <item name="cardElevation">2dp</item>
        <item name="contentPadding">0dp</item>
    </style>

    <!-- Splash screen — status bar blends with green background -->
    <style name="Theme.SkinSafe.Splash" parent="Theme.SkinSafe">
        <item name="android:statusBarColor">@color/green_primary</item>
        <item name="android:navigationBarColor">@color/green_primary</item>
    </style>

    <!-- Scan screen — dark theme for camera view -->
    <style name="Theme.SkinSafe.Scan" parent="Theme.SkinSafe">
        <item name="android:statusBarColor">@color/text_primary</item>
        <item name="android:windowBackground">@color/text_primary</item>
    </style>

    <!-- Dialog style -->
    <style name="SkinSafe.Dialog" parent="ThemeOverlay.MaterialComponents.Dialog.Alert">
        <item name="colorPrimary">@color/green_primary</item>
        <item name="buttonBarPositiveButtonStyle">@style/SkinSafe.Dialog.ButtonPositive</item>
        <item name="buttonBarNegativeButtonStyle">@style/SkinSafe.Dialog.ButtonNegative</item>
    </style>

    <style name="SkinSafe.Dialog.ButtonPositive" parent="Widget.MaterialComponents.Button.TextButton.Dialog">
        <item name="android:textColor">@color/green_primary</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="SkinSafe.Dialog.ButtonNegative" parent="Widget.MaterialComponents.Button.TextButton.Dialog">
        <item name="android:textColor">@color/text_secondary</item>
    </style>

</resources>