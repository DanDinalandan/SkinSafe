<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="#FFFFFF">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <TextView
            android:id="@+id/dialog_tv_name"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Phenoxyethanol"
            android:textSize="20sp"
            android:textStyle="bold"
            android:textColor="#1A1A1A"
            android:layout_marginBottom="4dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="16dp">

            <TextView
                android:id="@+id/dialog_tv_category"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Preservative"
                android:textSize="13sp"
                android:textColor="#888888" />

            <TextView
                android:id="@+id/dialog_tv_safety"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="CAUTION"
                android:textSize="12sp"
                android:textStyle="bold" />
        </LinearLayout>

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#F0F0F0"
            android:layout_marginBottom="16dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="WHAT IT DOES"
            android:textColor="#888888"
            android:textSize="11sp"
            android:letterSpacing="0.1"
            android:layout_marginBottom="4dp" />

        <TextView
            android:id="@+id/dialog_tv_description"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Description here."
            android:textSize="14sp"
            android:textColor="#333333"
            android:lineSpacingExtra="3dp"
            android:layout_marginBottom="16dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="RISK NOTE"
            android:textColor="#888888"
            android:textSize="11sp"
            android:letterSpacing="0.1"
            android:layout_marginBottom="4dp" />

        <TextView
            android:id="@+id/dialog_tv_risk"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Risk note here."
            android:textSize="14sp"
            android:textColor="#E65100"
            android:lineSpacingExtra="3dp"
            android:layout_marginBottom="16dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="8dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="🤖 AI EXPLANATION"
                android:textColor="#2E6B3E"
                android:textSize="11sp"
                android:textStyle="bold"
                android:letterSpacing="0.1" />

            <ProgressBar android:id="@+id/dialog_progress_ai"
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:indeterminateTint="#2E6B3E" />

        </LinearLayout>

        <TextView
            android:id="@+id/dialog_tv_ai_explanation"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text=""
            android:textSize="14sp"
            android:textColor="#333333"
            android:lineSpacingExtra="3dp"
            android:layout_marginBottom="20dp" />

        <Button
            android:id="@+id/dialog_btn_close"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:text="Close"
            android:backgroundTint="#527860"
            android:textColor="#FFFFFF" />
    </LinearLayout>
</ScrollView>