<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="16dp"
    app:cardBackgroundColor="#F8F8F5"
    app:cardCornerRadius="24dp"
    app:cardElevation="0dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="24dp"
            android:fontFamily="serif"
            android:text="Edit Skin Profile"
            android:textColor="#1A1A1A"
            android:textSize="22sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            android:letterSpacing="0.05"
            android:text="SKIN TYPE"
            android:textColor="#546E7A"
            android:textSize="11sp"
            android:textStyle="bold" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:layout_marginBottom="8dp"
            android:orientation="horizontal">
            <CheckBox android:id="@+id/cb_oily" android:layout_width="wrap_content" android:layout_height="40dp" android:layout_marginEnd="8dp" android:background="@drawable/selector_pill" android:button="@null" android:gravity="center" android:paddingHorizontal="20dp" android:text="Oily" android:textColor="@color/selector_pill_text" android:textSize="14sp" />
            <CheckBox android:id="@+id/cb_dry" android:layout_width="wrap_content" android:layout_height="40dp" android:layout_marginEnd="8dp" android:background="@drawable/selector_pill" android:button="@null" android:gravity="center" android:paddingHorizontal="20dp" android:text="Dry" android:textColor="@color/selector_pill_text" android:textSize="14sp" />
            <CheckBox android:id="@+id/cb_combination" android:layout_width="wrap_content" android:layout_height="40dp" android:background="@drawable/selector_pill" android:button="@null" android:gravity="center" android:paddingHorizontal="20dp" android:text="Combination" android:textColor="@color/selector_pill_text" android:textSize="14sp" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:layout_marginBottom="24dp"
            android:orientation="horizontal">
            <CheckBox android:id="@+id/cb_sensitive" android:layout_width="wrap_content" android:layout_height="40dp" android:layout_marginEnd="8dp" android:background="@drawable/selector_pill" android:button="@null" android:gravity="center" android:paddingHorizontal="20dp" android:text="Sensitive" android:textColor="@color/selector_pill_text" android:textSize="14sp" />
            <CheckBox android:id="@+id/cb_normal" android:layout_width="wrap_content" android:layout_height="40dp" android:background="@drawable/selector_pill" android:button="@null" android:gravity="center" android:paddingHorizontal="20dp" android:text="Normal" android:textColor="@color/selector_pill_text" android:textSize="14sp" />
        </LinearLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            android:letterSpacing="0.05"
            android:text="CONCERNS &amp; PREFERENCES"
            android:textColor="#546E7A"
            android:textSize="11sp"
            android:textStyle="bold" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:layout_marginBottom="8dp"
            android:orientation="horizontal">
            <CheckBox android:id="@+id/cb_no_fragrance" android:layout_width="wrap_content" android:layout_height="40dp" android:layout_marginEnd="8dp" android:background="@drawable/selector_pill" android:button="@null" android:gravity="center" android:paddingHorizontal="16dp" android:text="No Fragrance" android:textColor="@color/selector_pill_text" android:textSize="14sp" />
            <CheckBox android:id="@+id/cb_avoid_parabens" android:layout_width="wrap_content" android:layout_height="40dp" android:background="@drawable/selector_pill" android:button="@null" android:gravity="center" android:paddingHorizontal="16dp" android:text="Avoid Parabens" android:textColor="@color/selector_pill_text" android:textSize="14sp" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:layout_marginBottom="16dp"
            android:orientation="horizontal">
            <CheckBox android:id="@+id/cb_acne_prone" android:layout_width="wrap_content" android:layout_height="40dp" android:background="@drawable/selector_pill" android:button="@null" android:gravity="center" android:paddingHorizontal="20dp" android:text="Acne-prone" android:textColor="@color/selector_pill_text" android:textSize="14sp" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:gravity="end"
            android:orientation="horizontal">

            <Button
                android:id="@+id/btn_cancel_edit"
                android:layout_width="wrap_content"
                android:layout_height="48dp"
                android:layout_marginEnd="8dp"
                android:background="@android:color/transparent"
                android:text="Cancel"
                android:textAllCaps="false"
                android:textColor="#78909C"
                android:textSize="15sp"
                android:textStyle="bold" />

            <Button
                android:id="@+id/btn_save_edit"
                android:layout_width="wrap_content"
                android:layout_height="48dp"
                android:background="@drawable/button_green"
                android:paddingHorizontal="24dp"
                android:text="Save Profile"
                android:textAllCaps="false"
                android:textColor="#FFFFFF"
                android:textSize="15sp"
                android:textStyle="bold" />
        </LinearLayout>
    </LinearLayout>
</androidx.cardview.widget.CardView>