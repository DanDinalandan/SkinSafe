<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="#FFFFFF">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="SKIN TYPES"
            android:textColor="#888888"
            android:textSize="11sp"
            android:letterSpacing="0.1"
            android:layout_marginBottom="10dp" />

        <CheckBox
            android:id="@+id/cb_oily"
            android:layout_width="wrap_content"
            android:layout_height="44dp"
            android:text="Oily"
            android:textSize="15sp"
            android:buttonTint="#2E6B3E"
            android:paddingStart="8dp" />

        <CheckBox
            android:id="@+id/cb_dry"
            android:layout_width="wrap_content"
            android:layout_height="44dp"
            android:text="Dry"
            android:textSize="15sp"
            android:buttonTint="#2E6B3E"
            android:paddingStart="8dp" />

        <CheckBox
            android:id="@+id/cb_combination"
            android:layout_width="wrap_content"
            android:layout_height="44dp"
            android:text="Combination"
            android:textSize="15sp"
            android:buttonTint="#2E6B3E"
            android:paddingStart="8dp" />

        <CheckBox
            android:id="@+id/cb_sensitive"
            android:layout_width="wrap_content"
            android:layout_height="44dp"
            android:text="Sensitive"
            android:textSize="15sp"
            android:buttonTint="#2E6B3E"
            android:paddingStart="8dp" />

        <CheckBox
            android:id="@+id/cb_normal"
            android:layout_width="wrap_content"
            android:layout_height="44dp"
            android:text="Normal"
            android:textSize="15sp"
            android:buttonTint="#2E6B3E"
            android:paddingStart="8dp"
            android:layout_marginBottom="16dp" />

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#EEEEEE"
            android:layout_marginBottom="16dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="PREFERENCES / CONCERNS"
            android:textColor="#888888"
            android:textSize="11sp"
            android:letterSpacing="0.1"
            android:layout_marginBottom="10dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="These preferences flag relevant ingredients during scans."
            android:textSize="12sp"
            android:textColor="#AAAAAA"
            android:layout_marginBottom="10dp" />

        <CheckBox
            android:id="@+id/cb_no_fragrance"
            android:layout_width="wrap_content"
            android:layout_height="44dp"
            android:text="No Fragrance"
            android:textSize="15sp"
            android:buttonTint="#2E6B3E"
            android:paddingStart="8dp" />

        <CheckBox
            android:id="@+id/cb_avoid_parabens"
            android:layout_width="wrap_content"
            android:layout_height="44dp"
            android:text="Avoid Parabens"
            android:textSize="15sp"
            android:buttonTint="#2E6B3E"
            android:paddingStart="8dp" />

        <CheckBox
            android:id="@+id/cb_acne_prone"
            android:layout_width="wrap_content"
            android:layout_height="44dp"
            android:text="Acne-prone"
            android:textSize="15sp"
            android:buttonTint="#2E6B3E"
            android:paddingStart="8dp" />

    </LinearLayout>
</ScrollView>