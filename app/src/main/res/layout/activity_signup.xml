<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F8F8F5"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <RelativeLayout
            android:layout_width="wrap_content"
            android:layout_height="48dp"
            android:layout_marginBottom="8dp">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="match_parent"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="8dp"
                    android:text="‹"
                    android:textColor="#4E735B"
                    android:textSize="28sp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Back"
                    android:textColor="#4E735B"
                    android:textSize="14sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <ImageButton
                android:id="@+id/btn_back"
                android:layout_width="80dp"
                android:layout_height="match_parent"
                android:background="@android:color/transparent" />
        </RelativeLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="3dp"
            android:layout_marginBottom="24dp"
            android:orientation="horizontal">
            <View
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_marginEnd="6dp"
                android:layout_weight="1"
                android:background="#4E735B" />
            <View
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_marginEnd="6dp"
                android:layout_weight="1"
                android:background="#4E735B" />
            <View
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:background="#C8E6C9" />
        </LinearLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="serif"
            android:text="Create Account"
            android:textColor="#1A1A1A"
            android:textSize="32sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:layout_marginBottom="32dp"
            android:text="Tell us about your skin to personalize results"
            android:textColor="#78909C"
            android:textSize="14sp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            android:orientation="horizontal">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginEnd="8dp"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="6dp"
                    android:letterSpacing="0.05"
                    android:text="FIRST NAME"
                    android:textColor="#546E7A"
                    android:textSize="11sp"
                    android:textStyle="bold" />

                <EditText
                    android:id="@+id/et_first_name"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:background="@drawable/bg_setting_item"
                    android:hint="enter name"
                    android:inputType="textPersonName"
                    android:paddingHorizontal="16dp"
                    android:textColor="#1A1A1A"
                    android:textColorHint="#9E9E9E"
                    android:textSize="15sp" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="6dp"
                    android:letterSpacing="0.05"
                    android:text="LAST NAME"
                    android:textColor="#546E7A"
                    android:textSize="11sp"
                    android:textStyle="bold" />

                <EditText
                    android:id="@+id/et_last_name"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:background="@drawable/bg_setting_item"
                    android:hint="enter surname"
                    android:inputType="textPersonName"
                    android:paddingHorizontal="16dp"
                    android:textColor="#1A1A1A"
                    android:textColorHint="#9E9E9E"
                    android:textSize="15sp" />
            </LinearLayout>
        </LinearLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="6dp"
            android:letterSpacing="0.05"
            android:text="EMAIL"
            android:textColor="#546E7A"
            android:textSize="11sp"
            android:textStyle="bold" />

        <EditText
            android:id="@+id/et_email"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:layout_marginBottom="16dp"
            android:background="@drawable/bg_setting_item"
            android:hint="enter email"
            android:inputType="textEmailAddress"
            android:paddingHorizontal="16dp"
            android:textColor="#1A1A1A"
            android:textColorHint="#9E9E9E"
            android:textSize="15sp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="6dp"
            android:letterSpacing="0.05"
            android:text="PASSWORD"
            android:textColor="#546E7A"
            android:textSize="11sp"
            android:textStyle="bold" />

        <EditText
            android:id="@+id/et_password"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:layout_marginBottom="24dp"
            android:background="@drawable/bg_setting_item"
            android:hint="enter password"
            android:inputType="textPassword"
            android:paddingHorizontal="16dp"
            android:textColor="#1A1A1A"
            android:textColorHint="#9E9E9E"
            android:textSize="15sp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            android:letterSpacing="0.05"
            android:text="SKIN TYPE"
            android:textColor="#546E7A"
            android:textSize="11sp"
            android:textStyle="bold" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:layout_marginBottom="8dp"
            android:orientation="horizontal">

            <CheckBox
                android:id="@+id/cb_oily"
                android:layout_width="wrap_content"
                android:layout_height="40dp"
                android:layout_marginEnd="8dp"
                android:background="@drawable/selector_pill"
                android:button="@null"
                android:gravity="center"
                android:paddingHorizontal="20dp"
                android:text="Oily"
                android:textColor="@color/selector_pill_text"
                android:textSize="14sp" />

            <CheckBox
                android:id="@+id/cb_dry"
                android:layout_width="wrap_content"
                android:layout_height="40dp"
                android:layout_marginEnd="8dp"
                android:background="@drawable/selector_pill"
                android:button="@null"
                android:gravity="center"
                android:paddingHorizontal="20dp"
                android:text="Dry"
                android:textColor="@color/selector_pill_text"
                android:textSize="14sp" />

            <CheckBox
                android:id="@+id/cb_combination"
                android:layout_width="wrap_content"
                android:layout_height="40dp"
                android:background="@drawable/selector_pill"
                android:button="@null"
                android:gravity="center"
                android:paddingHorizontal="20dp"
                android:text="Combination"
                android:textColor="@color/selector_pill_text"
                android:textSize="14sp" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:layout_marginBottom="24dp"
            android:orientation="horizontal">

            <CheckBox
                android:id="@+id/cb_sensitive"
                android:layout_width="wrap_content"
                android:layout_height="40dp"
                android:layout_marginEnd="8dp"
                android:background="@drawable/selector_pill"
                android:button="@null"
                android:gravity="center"
                android:paddingHorizontal="20dp"
                android:text="Sensitive"
                android:textColor="@color/selector_pill_text"
                android:textSize="14sp" />

            <CheckBox
                android:id="@+id/cb_normal"
                android:layout_width="wrap_content"
                android:layout_height="40dp"
                android:background="@drawable/selector_pill"
                android:button="@null"
                android:gravity="center"
                android:paddingHorizontal="20dp"
                android:text="Normal"
                android:textColor="@color/selector_pill_text"
                android:textSize="14sp" />
        </LinearLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            android:letterSpacing="0.05"
            android:text="CONCERNS &amp; PREFERENCES"
            android:textColor="#546E7A"
            android:textSize="11sp"
            android:textStyle="bold" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:layout_marginBottom="8dp"
            android:orientation="horizontal">

            <CheckBox
                android:id="@+id/cb_no_fragrance"
                android:layout_width="wrap_content"
                android:layout_height="40dp"
                android:layout_marginEnd="8dp"
                android:background="@drawable/selector_pill"
                android:button="@null"
                android:gravity="center"
                android:paddingHorizontal="16dp"
                android:text="No Fragrance"
                android:textColor="@color/selector_pill_text"
                android:textSize="14sp" />

            <CheckBox
                android:id="@+id/cb_avoid_parabens"
                android:layout_width="wrap_content"
                android:layout_height="40dp"
                android:background="@drawable/selector_pill"
                android:button="@null"
                android:gravity="center"
                android:paddingHorizontal="16dp"
                android:text="Avoid Parabens"
                android:textColor="@color/selector_pill_text"
                android:textSize="14sp" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:layout_marginBottom="32dp"
            android:orientation="horizontal">

            <CheckBox
                android:id="@+id/cb_acne_prone"
                android:layout_width="wrap_content"
                android:layout_height="40dp"
                android:background="@drawable/selector_pill"
                android:button="@null"
                android:gravity="center"
                android:paddingHorizontal="20dp"
                android:text="Acne-prone"
                android:textColor="@color/selector_pill_text"
                android:textSize="14sp" />
        </LinearLayout>

        <Button
            android:id="@+id/btn_create_account"
            android:layout_width="match_parent"
            android:layout_height="64dp"
            android:layout_marginBottom="24dp"
            android:background="@drawable/button_green"
            android:text="Create Account"
            android:textAllCaps="false"
            android:textColor="#FFFFFF"
            android:textSize="16sp"
            android:textStyle="bold" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:orientation="horizontal">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Already have an account? "
                android:textColor="#78909C"
                android:textSize="14sp" />

            <TextView
                android:id="@+id/tv_signin_link"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Sign In"
                android:textColor="#4E735B"
                android:textSize="14sp"
                android:textStyle="bold" />
        </LinearLayout>
    </LinearLayout>
</ScrollView>