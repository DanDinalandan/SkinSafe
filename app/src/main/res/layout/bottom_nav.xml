<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="72dp"
    android:background="#FFFFFF"
    android:elevation="16dp"
    android:gravity="center_vertical"
    android:orientation="horizontal"
    android:paddingHorizontal="4dp">

    <LinearLayout
        android:id="@+id/nav_home"
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="1"
        android:background="?attr/selectableItemBackground"
        android:gravity="center"
        android:orientation="vertical">
        <ImageView
            android:id="@+id/ic_nav_home"
            android:layout_width="26dp"
            android:layout_height="26dp"
            android:layout_marginBottom="4dp"
            android:src="@drawable/ic_home"
            app:tint="#9E9E9E" />
        <TextView
            android:id="@+id/tv_nav_home"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Home"
            android:textColor="#9E9E9E"
            android:textSize="11sp" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/nav_search"
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="1"
        android:background="?attr/selectableItemBackground"
        android:gravity="center"
        android:orientation="vertical">
        <ImageView
            android:id="@+id/ic_nav_search"
            android:layout_width="26dp"
            android:layout_height="26dp"
            android:layout_marginBottom="4dp"
            android:src="@drawable/ic_search"
            app:tint="#9E9E9E" />
        <TextView
            android:id="@+id/tv_nav_search"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Search"
            android:textColor="#9E9E9E"
            android:textSize="11sp" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/nav_scan"
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="1.1"
        android:background="?attr/selectableItemBackground"
        android:gravity="center"
        android:orientation="vertical">
        <ImageView
            android:layout_width="56dp"
            android:layout_height="56dp"
            android:background="@drawable/button_green"
            android:padding="14dp"
            android:src="@drawable/ic_scan"
            app:tint="#FFFFFF" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/nav_history"
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="1"
        android:background="?attr/selectableItemBackground"
        android:gravity="center"
        android:orientation="vertical">
        <ImageView
            android:id="@+id/ic_nav_history"
            android:layout_width="26dp"
            android:layout_height="26dp"
            android:layout_marginBottom="4dp"
            android:src="@drawable/ic_history"
            app:tint="#9E9E9E" />
        <TextView
            android:id="@+id/tv_nav_history"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="History"
            android:textColor="#9E9E9E"
            android:textSize="11sp" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/nav_profile"
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="1"
        android:background="?attr/selectableItemBackground"
        android:gravity="center"
        android:orientation="vertical">
        <ImageView
            android:id="@+id/ic_nav_profile"
            android:layout_width="26dp"
            android:layout_height="26dp"
            android:layout_marginBottom="4dp"
            android:src="@drawable/ic_profile"
            app:tint="#9E9E9E" />
        <TextView
            android:id="@+id/tv_nav_profile"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Profile"
            android:textColor="#9E9E9E"
            android:textSize="11sp" />
    </LinearLayout>

</LinearLayout>