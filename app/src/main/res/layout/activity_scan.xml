<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F8F8F5">

    <LinearLayout
        android:id="@+id/header_layout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_alignParentTop="true"
        android:background="#527860"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingHorizontal="16dp"
        android:paddingTop="40dp"
        android:paddingBottom="20dp">

        <ImageButton
            android:id="@+id/btn_back"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@drawable/ic_arrowback"
            app:tint="#FFFFFF" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:layout_weight="1"
            android:fontFamily="serif"
            android:text="Scan Product"
            android:textColor="#FFFFFF"
            android:textSize="26sp"
            android:textStyle="bold" />

        <ProgressBar
            android:id="@+id/progress_bar"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:indeterminateTint="#C8E6C9"
            android:visibility="gone" />

        <TextView
            android:id="@+id/tv_scan_status"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:text="Status"
            android:textColor="#FFFFFF"
            android:textSize="14sp"
            android:visibility="gone" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/tabs_layout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_below="@id/header_layout"
        android:orientation="horizontal"
        android:paddingHorizontal="20dp"
        android:paddingTop="20dp"
        android:paddingBottom="16dp">

        <Button
            android:id="@+id/btn_tab_camera"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_marginEnd="8dp"
            android:layout_weight="1"
            android:background="@drawable/bg_setting_item"
            app:backgroundTint="@null"
            android:text="Camera"
            android:textAllCaps="false"
            android:textColor="#4E735B"
            android:textSize="14sp"
            android:textStyle="bold" />

        <Button
            android:id="@+id/btn_tab_manual"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_marginEnd="8dp"
            android:layout_weight="1"
            android:background="@drawable/bg_setting_item"
            app:backgroundTint="@null"
            android:text="Manual"
            android:textAllCaps="false"
            android:textColor="#4E735B"
            android:textSize="14sp"
            android:textStyle="bold" />

        <Button
            android:id="@+id/btn_tab_voice"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:background="@drawable/bg_setting_item"
            app:backgroundTint="@null"
            android:text="Voice"
            android:textAllCaps="false"
            android:textColor="#4E735B"
            android:textSize="14sp"
            android:textStyle="bold" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/global_input_layout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_below="@id/tabs_layout"
        android:paddingHorizontal="20dp"
        android:paddingBottom="12dp">

        <EditText
            android:id="@+id/et_product_name"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:background="@drawable/bg_setting_item"
            android:hint="Product Name (Optional)"
            android:paddingHorizontal="16dp"
            android:textColor="#1A1A1A"
            android:textColorHint="#B0BEC5"
            android:textSize="15sp"
            android:singleLine="true" />
    </LinearLayout>

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_below="@id/global_input_layout"
        android:paddingHorizontal="20dp">

        <LinearLayout
            android:id="@+id/layout_camera"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:visibility="visible">

            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_marginBottom="24dp"
                android:layout_weight="1"
                app:cardBackgroundColor="#000000"
                app:cardCornerRadius="24dp"
                app:cardElevation="4dp">

                <FrameLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent">

                    <androidx.camera.view.PreviewView
                        android:id="@+id/preview_view"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent" />

                    <View
                        android:layout_width="280dp"
                        android:layout_height="280dp"
                        android:layout_gravity="center"
                        android:background="@drawable/scan_frame_overlay" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_gravity="bottom"
                        android:layout_marginBottom="24dp"
                        android:gravity="center"
                        android:text="Position ingredient label inside frame"
                        android:textColor="#FFFFFF"
                        android:textSize="14sp"
                        android:shadowColor="#80000000"
                        android:shadowDx="1"
                        android:shadowDy="1"
                        android:shadowRadius="2" />
                </FrameLayout>
            </androidx.cardview.widget.CardView>

            <Button
                android:id="@+id/btn_capture"
                android:layout_width="match_parent"
                android:layout_height="64dp"
                android:layout_marginBottom="24dp"
                android:background="@drawable/button_green"
                android:backgroundTint="#4E735B"
                android:text="✓ Analyze Ingredients"
                android:textAllCaps="false"
                android:textColor="#FFFFFF"
                android:textSize="16sp"
                android:textStyle="bold" />
        </LinearLayout>

        <ScrollView
            android:id="@+id/layout_manual"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:clipToPadding="false"
            android:visibility="gone">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="8dp"
                    android:letterSpacing="0.05"
                    android:text="INGREDIENT LIST"
                    android:textColor="#546E7A"
                    android:textSize="11sp"
                    android:textStyle="bold" />

                <EditText
                    android:id="@+id/et_ingredients"
                    android:layout_width="match_parent"
                    android:layout_height="280dp"
                    android:layout_marginBottom="24dp"
                    android:background="@drawable/bg_setting_item"
                    android:gravity="top|start"
                    android:hint="Paste or type ingredients here...\ne.g. Water, Niacinamide, Zinc PCA, Glycerin..."
                    android:inputType="textMultiLine"
                    android:padding="16dp"
                    android:textColor="#1A1A1A"
                    android:textColorHint="#B0BEC5"
                    android:textSize="15sp"
                    android:lineSpacingExtra="4dp"/>

                <Button
                    android:id="@+id/btn_analyze_manual"
                    android:layout_width="match_parent"
                    android:layout_height="64dp"
                    android:layout_marginBottom="24dp"
                    android:background="@drawable/button_green"
                    android:backgroundTint="#4E735B"
                    android:text="✓ Analyze Ingredients"
                    android:textAllCaps="false"
                    android:textColor="#FFFFFF"
                    android:textSize="16sp"
                    android:textStyle="bold" />
            </LinearLayout>
        </ScrollView>

        <LinearLayout
            android:id="@+id/layout_voice"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:gravity="center_horizontal"
            android:orientation="vertical"
            android:visibility="gone">

            <TextView
                android:id="@+id/tv_voice_status"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:layout_marginBottom="24dp"
                android:gravity="center"
                android:lineSpacingExtra="6dp"
                android:text="Tap the microphone and say ingredient names separated by commas"
                android:textColor="#546E7A"
                android:textSize="16sp" />

            <ImageButton
                android:id="@+id/btn_voice_start"
                android:layout_width="96dp"
                android:layout_height="96dp"
                android:layout_marginBottom="16dp"
                android:background="@drawable/button_green"
                android:backgroundTint="#4E735B"
                android:src="@drawable/ic_voice"
                android:scaleType="centerInside"
                android:padding="12dp"
                app:tint="#FFFFFF" />

            <Button
                android:id="@+id/btn_voice_clear"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:layout_marginBottom="16dp"
                android:background="@android:color/transparent"
                android:text="↺ Clear"
                android:textAllCaps="false"
                android:textColor="#D32F2F"
                android:textSize="14sp"
                android:visibility="gone" />

            <LinearLayout
                android:id="@+id/layout_voice_result"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="24dp"
                android:background="@drawable/bg_setting_item"
                android:orientation="vertical"
                android:padding="16dp"
                android:visibility="gone">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="8dp"
                    android:letterSpacing="0.05"
                    android:text="DETECTED INGREDIENTS:"
                    android:textColor="#9E9E9E"
                    android:textSize="11sp"
                    android:textStyle="bold" />

                <LinearLayout
                    android:id="@+id/ll_voice_ingredients"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical" />
            </LinearLayout>

            <Button
                android:id="@+id/btn_voice_analyze"
                android:layout_width="match_parent"
                android:layout_height="64dp"
                android:background="@drawable/button_green"
                android:backgroundTint="#4E735B"
                android:enabled="false"
                android:text="✓ Analyze Ingredients"
                android:textAllCaps="false"
                android:textColor="#FFFFFF"
                android:textSize="16sp"
                android:textStyle="bold" />
        </LinearLayout>
    </FrameLayout>
</RelativeLayout>
