<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F8F8F5">

    <LinearLayout
        android:id="@+id/header_layout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_alignParentTop="true"
        android:background="#527860"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingHorizontal="16dp"
        android:paddingTop="40dp"
        android:paddingBottom="20dp">

        <ImageButton
            android:id="@+id/btn_back"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@drawable/ic_arrowback"
            app:tint="#FFFFFF" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:layout_weight="1"
            android:fontFamily="serif"
            android:text="Edit Scan"
            android:textColor="#FFFFFF"
            android:textSize="26sp"
            android:textStyle="bold" />

        <ProgressBar
            android:id="@+id/progress_bar"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:indeterminateTint="#C8E6C9"
            android:visibility="gone" />
    </LinearLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_below="@id/header_layout"
        android:paddingHorizontal="20dp"
        android:paddingTop="24dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp"
                android:letterSpacing="0.05"
                android:text="PRODUCT NAME"
                android:textColor="#546E7A"
                android:textSize="11sp"
                android:textStyle="bold" />

            <EditText
                android:id="@+id/et_edit_name"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:layout_marginBottom="24dp"
                android:background="@drawable/bg_setting_item"
                android:paddingHorizontal="16dp"
                android:singleLine="true"
                android:textColor="#1A1A1A"
                android:textSize="15sp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp"
                android:letterSpacing="0.05"
                android:text="RAW INGREDIENTS"
                android:textColor="#546E7A"
                android:textSize="11sp"
                android:textStyle="bold" />

            <EditText
                android:id="@+id/et_edit_ingredients"
                android:layout_width="match_parent"
                android:layout_height="300dp"
                android:layout_marginBottom="32dp"
                android:background="@drawable/bg_setting_item"
                android:gravity="top|start"
                android:inputType="textMultiLine"
                android:lineSpacingExtra="4dp"
                android:padding="16dp"
                android:textColor="#1A1A1A"
                android:textSize="15sp" />

            <Button
                android:id="@+id/btn_save_changes"
                android:layout_width="match_parent"
                android:layout_height="64dp"
                android:layout_marginBottom="40dp"
                android:background="@drawable/button_green"
                app:backgroundTint="@null"
                android:text="✓ Re-Analyze &amp; Save"
                android:textAllCaps="false"
                android:textColor="#FFFFFF"
                android:textSize="16sp"
                android:textStyle="bold" />
        </LinearLayout>
    </ScrollView>
</RelativeLayout>